# Video Player: https://github.com/jellyfin/jellyfin-desktop
# uses libmpv inside of the main process to play videos,
# spawns QtWebEngineProcess background processes for web UI drawing
{ "name": "jellyfin-desktop", "type": "Player-Video" }

